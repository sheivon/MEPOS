@{
    ViewBag.Title = "Customers";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card border-2 border-success">
    <div class="card-header shadow py-1">
        <div class="d-flex align-items-center">
            <h4 class="card-title ">@ViewBag.Title</h4>
            <button class="btn btn-sm btn-outline-success btn-round ms-auto"
                    data-bs-toggle="modal"
                    data-bs-target="#customerModal">
                <i class="fa fa-plus"></i>
                Add @ViewBag.Title
            </button> 
            <button class="btn btn-sm btn-success btn-round mx-1" onclick="print()">
                <i class="fa fa-print"></i>
                Print @ViewBag.Title
            </button>
        </div>
    </div>
    <div class="card-body px-2 py-0 ">
        <!-- Modal -->
        <div class="modal fade" id="customerModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="Modaltitle" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <div class="modal-header">
                        <h1 class="modal-title fs-5" id="Modaltitle">@ViewBag.Title</h1>
                        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <form id="frm">
                            <div class="row">
                                <div class="col-sm-12">
                                    <input id="txtCustomerId" hidden value="0" />
                                    <div class="form-group form-group-default">
                                        <label for="txtFirstName">First Name</label>
                                        <input id="txtFirstName" type="text" class="form-control" placeholder="Customer first name" />
                                    </div>
                                </div>
                                <div class="col-sm-12">
                                    <div class="form-group form-group-default">
                                        <label for="txtLastName">Last Name</label>
                                        <input id="txtLastName" type="text" class="form-control" placeholder="Customer last name" />
                                    </div>
                                </div>
                                <div class="col-md-12">
                                    <div class="form-group form-group-default">
                                        <label for="txtEmail">Email</label>
                                        <input id="txtEmail" type="email" class="form-control" placeholder="Customer email" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group form-group-default">
                                        <label for="txtCedula">Cedula</label>
                                        <input id="txtCedula" type="text" class="form-control" placeholder="Customer Cedula" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group form-group-default">
                                        <label for="txtPhone">Phone</label>
                                        <input id="txtPhone" type="text" class="form-control" placeholder="Customer phone number" />
                                    </div>
                                </div>
                                <div class="col-md-6">
                                    <div class="form-group form-group-default mb-3">
                                        <label for="chkIsDeleted">Is Deleted?</label>
                                        <input id="chkIsDeleted" type="checkbox" class="form-check-input" />
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" onclick="clearModal()"><i class="fas fa-times"> </i> Close</button>
                        <button type="button" class="btn btn-primary" onclick="submitCustomer();"><i class="fas fa-save"></i> Save</button>
                    </div>
                </div>
            </div>
        </div>

        <div class="table-responsive table-responsive-sm small">
            <table id="customertbl" class="display table table-sm table-striped table-hover" width="100%" cellspacing="0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>First Name</th>
                        <th>Last Name</th>
                        <th>Email</th>
                        <th>Cedula</th>
                        <th>phone</th>
                        <th>Deleted</th>
                        <th>Register</th>
                        <th style="width: 5%">Action</th>
                    </tr>
                </thead>
                <tfoot>
                    <tr>
                        <th>#</th>
                        <th>First Name</th>
                        <th>Last Name</th>
                        <th>Email</th>
                        <th>Cedula</th>
                        <th>phone</th>
                        <th>Deleted</th>
                        <th>Register</th>
                        <th>Action</th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>
</div>

@section scripts{
    <script>
        $("#customertbl").DataTable({
            "ajax": {
                "url": "@Url.Action("GetCustomer", "Account")", // Adjust this to your action method for products
                "type": "GET",
                "dataSrc": "data" // The actual data is inside the "data" property of the response
            },
            "columns": [
                { "data": "customer_id" },
                { "data": "first_name" },
                { "data": "last_name" },
                { "data": "email" },
                { "data": "cedula" },
                { "data": "phone" },
                {
                    "data": "isdelete", render: function (data) {
                        if (data == false)

                            return '<span class="rounded-pill bg-success  px-3 text-light">false</span>';
                        else
                            return '<span class="rounded-pill bg-warning px-3 text-light">true</span>';
                    }
                },
                {
                    "data": "created_at",
                    "render": function (data, type, row) {
                        // Convert the /Date(...) format to a JavaScript Date object
                        var date = new Date(parseInt(data.replace(/\/Date\((\d+)\)\//, '$1')));
                        return date.toLocaleString(); // Format as a human-readable string
                    }
                } ,{ 
                    "data": null,
                    "render": function (data, type, row) {
                        return `<div class="d-flex m-0 p-0">
                                    <a class="btn btn-link btn-primary py-0" onclick="openCustomerModal(${row.customer_id})"><i class="fa fa-edit"></i></a>
                                    ${row.isdelete==false ? `<a class="btn btn-link btn-danger py-0" onclick="deleteCustomer(${row.customer_id})"><i class="fa fa-trash"></i></a>` : ''}
                                </div>`;
                        } 
        //            "render": function (data, type, row) {
        //                return `<div class="d-flex m-0 p-0">
								//<a class="btn btn-link btn-primary py-0" onclick="openCustomerModal(${row.customer_id})"><i class="fa fa-edit"></i></a>
								//${row.isdelete ? <a class="btn btn-link btn-danger py-0" onclick="deleteCustomer(${row.customer_id})"><i class="fa fa-times"></i></a> : "" } 
        //                     </div>`;
        //            }
                }
        ] 
        });

        function editCustomer(cid) {
            $.ajax({
                url: '@Url.Action("GetCustomerId", "Account")',
                type: 'GET',
                data: { id:cid },
                success: function (response) {
                    var data = response.data[0]; //get first data
                    if (data != null) {
                        $("#customerId").val(data.customer_id);
                        $("#first_name").val(data.first_name);
                        $("#Last_Name").val(data.last_name);
                        $("#customerEmail").val(data.email);
                        $("#customerCedula").val(data.cedula);
                        $("#customerPhone").val(data.phone);
                        $("#customerModalLabel").text("Edit Customer");
                        $("#customerModal").modal('show');
                        console.log(data);
                    }
                    console.log(response);
                },
                error: function () {
                    swal({ title: 'Error occurred while loading customer data' });
                }
            });
        }

        function deleteCustomer(cid) {

         /*   document.getElementById('deleteCustomer').addEventListener('click', function () {*/
                swal({
                    title: 'Are you sure?',
                    text: "Do you really want to delete this customer?",
                    icon: 'warning',
                    buttons: {
                        cancel: {
                            text: "No",
                            value: false,
                            visible: true,
                            className: "btn-danger",
                        },
                        confirm: {
                            text: "Yes",
                            value: true,
                            visible: true,
                            className: "btn-success",
                        },
                    },
                }).then((isConfirmed) => {
                    if (isConfirmed) {
                           $.ajax({
                               url: '@Url.Action("DelCustomer", "Account")',
                               type: 'GET',
                               data: { id:cid },
                               success: function (data) {
                                   if (data.data = true) {

                                       swal({ title: "Customer deleted success full!", icon:"success"})
                                   }
                                   else {

                                       swal({ title: "Customer deleted Failed!",icon:"warning"})
                                   }

                               },
                               error: function () {
                                   swal({ title: 'Error occurred while loading customer data' });
                               }
                           });
                        location.reload();
                    } else {
                        swal({ title:'Delection canceled successfully!',icon: 'warning'});
                    }
                });
          /*  });*/
        }
        function openCustomerModal(customerId) {
            if (customerId) {
                // Edit customer
                $.ajax({
                    url: '/Account/GetCustomerDetails', // Adjust with your actual endpoint
                    type: 'GET',
                    data: { id: customerId },
                    success: function (response) {
                        if (response.data) {
                            // Populate the modal with existing customer data
                            $('#txtCustomerId').val(response.data.customer_id);
                            $('#txtFirstName').val(response.data.first_name);
                            $('#txtLastName').val(response.data.last_name);
                            $('#txtEmail').val(response.data.email);
                            $('#txtCedula').val(response.data.cedula);
                            $('#txtPhone').val(response.data.phone);
                            $('#chkIsDeleted').prop('checked', response.data.isdelete);
                            $('#txtCreatedAt').val(response.data.created_at); // Or format if needed
                            // Show modal
                            $('#customerModal').modal('show');
                        } else {
                            alert('Customer not found');
                        }
                    },
                    error: function () {
                        alert('Error loading customer details');
                    }
                });
            } else {
                // Add new customer (reset modal)
                clearModal();
                $('#customerModal').modal('show');
            }
        }

        function clearModal() {
            // Reset form values
            $('#txtCustomerId').val(0);
            $('#txtFirstName').val('');
            $('#txtLastName').val('');
            $('#txtEmail').val('');
            $('#txtCedula').val('');
            $('#txtPhone').val('');
            $('#chkIsDeleted').prop('checked', false);
            $('#txtCreatedAt').val('');
        }

        function submitCustomer() {
            var customer = {
                customer_id: $('#txtCustomerId').val(),
                first_name: $('#txtFirstName').val(),
                last_name: $('#txtLastName').val(),
                email: $('#txtEmail').val(),
                cedula: $('#txtCedula').val(),
                phone: $('#txtPhone').val(),
                isdelete: $('#chkIsDeleted').prop('checked'),
                created_at: $('#txtCreatedAt').val() // Optionally can omit this if backend will set it
            };
            // Submit via AJAX
            $.ajax({
                url: '/Account/SaveCustomer', // Adjust with your actual endpoint
                type: 'POST',
                data: customer,
                success: function (response) {
                    if (response.success) {
                        swal({ title: 'Customer saved successfully', icon: "success" });
                    } else {
                        swal({ title: 'Error saving customer', icon: "danger" });
                    }
                },
                error: function () {
                    swal({ title: 'Error submitting customer', icon: "Error" });
                }
            });
            // Optionally, reload the list or close the modal
            $('#customerModal').modal('hide'); // hid modal
            location.reload();
        }

    </script>


}