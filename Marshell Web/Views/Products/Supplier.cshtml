@{
    ViewBag.Title = "Supplier";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="card border-2 border-success">
    <div class="card-header py-1 shadow">
        <div class="d-flex align-items-center">
            <h4 class="card-title ">@ViewBag.Title</h4>
            <button class="btn btn-sm btn-primary btn-round ms-auto"
                    data-bs-toggle="modal"
                    data-bs-target="#supplierModal" onclick="clearModal()">
                <i class="fa fa-plus"></i>
                Add @ViewBag.Title
            </button>  
            <button class="btn btn-sm btn-success btn-round mx-1" onclick="printSuppliers()">
                <i class="fa fa-print"></i>
                Print @ViewBag.Title
            </button>
        </div>
    </div>
    <div class="card-body small px-1 m-1">
        <div class="table-responsive table-responsive-sm">
            <table table id="tblsupplier" class="table table-sm" width="100%" cellspacing="0" cellpadding="0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Contact Info</th>
                        <th>Modified</th>
                        <th style="width: 10%">Action</th>
                    </tr>
                </thead>
                <tfoot>
                    <tr>
                        <th>#</th>
                        <th>Name</th>
                        <th>Contact Info</th>
                        <th>Modified</th>
                        <th>Action</th>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div> 
         
    <div class="offcanvas offcanvas-end" tabindex="-1" id="offcanvasExample" aria-labelledby="offcanvasExampleLabel">
        <div class="offcanvas-header">
            <h5 class="offcanvas-title" id="offcanvasExampleLabel">@ViewBag.Title</h5>
            <button type="button" class="btn-close" data-bs-dismiss="offcanvas" aria-label="Close"></button>
        </div>
        <div class="offcanvas-body">
            <form id="efrm">
                <div class="row">
                    <div class="col-sm-12">
                        <input id="txteId" hidden value="0" placeholder="Id" />
                        <div class="form-group form-group-default">
                            <label>Name</label>
                            <input id="txtename" type="text" class="form-control" placeholder="Supplier name" />
                        </div>
                    </div>
                    <div class="col-md-12 ">
                        <div class="form-group form-group-default">
                            <label>Contact Info</label>
                            <input id="txteContactInfo" type="text" class="form-control" placeholder="Contact Information" />
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

 
<!-- Modal -->
<div class="modal fade" id="supplierModal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-labelledby="Modaltitle" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h1 class="modal-title fs-5" id="Modaltitle">@ViewBag.Title</h1>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="frm">
                    <div class="row">
                        <div class="col-sm-12">
                            <input id="txtId" hidden value="0" />
                            <div class="form-group form-group-default">
                                <label>Name</label>
                                <input id="txtname" type="text" class="form-control" placeholder="Supplier name" />
                            </div>
                        </div>
                        <div class="col-md-12 ">
                            <div class="form-group form-group-default">
                                <label>Contact Info</label>
                                <input id="txtContactInfo" type="text"  class="form-control" placeholder="Contact Information" />
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal" onclick="clearModal()"><i class="fas fa-times"> </i> Close</button>
                <button type="button" class="btn btn-primary" onclick="submit();"><i class="fas fa-save"></i> Save</button>
            </div>
        </div>
    </div>
</div>


@section scripts{
    <script>
    // Initialize the DataTable
    $('#tblsupplier').DataTable({
        "ajax": {
            "url": "@Url.Action("GetSuppliers", "Products")",
            "type": "GET"
        },
        "columns": [
            { "data": "supplier_id" },
            { "data": "name" },
            { "data": "contactinfo" },
            { "data": "created_at",
                "render": function (data) {
                    var date = new Date(parseInt(data.replace(/\/Date\((\d+)\)\//, '$1')));
                    return date.toLocaleString();}
            },
            { "data": null,
                "render": function (data, type, row) {
                    return `<div class="d-flex">
                                <a class="btn btn-link btn-primary btn-lg py-0 px-2" onclick="edititem(${row.supplier_id})"><i class="fa fa-edit"></i></a>
                                <a class="btn btn-link btn-danger py-0 px-2"><i class="fa fa-trash"></i></a>
                             </div>`;
                }
            }
        ]
    });

    // Function to clear modal fields
    function clearModal() {
        $('#frm')[0].reset(); // Reset form fields
        $('#txtId').val(0); // Reset hidden categoryId
        $('#txtname').val(''); // Reset hidden categoryId
        $('#txtContactInfo').val(''); // Reset hidden categoryId
        $('#modaltitle').text('@ViewBag.Title'); // Change modal title for Add
        $('#supplierModal').modal('show');
    }

    // Submit Add or Edit based on categoryId
    function submit() {
        var sId = $('#txtId').val();
        var sName = $('#txtname').val();
        var CINF = $('#txtContactInfo').val();

        var Supplier = {
            supplier_id: sId,
            Name: sName // Corrected here
            , contactinfo : CINF
        }; 
        $.ajax({
            url: '@Url.Action("SaveSupplier", "Products")',
            type: 'POST',
            data: Supplier,
            success: function (response) {
                if (response.data >= 1) {
                    $('#supplierModal').modal('hide'); // Close modal after success
                    $('#tblsupplier').DataTable().ajax.reload(); // Reload DataTable
                    swal({ icon: "success" });
                } else {
                    swal({ icon: "warning", title: "Error", text: "Fail to Save Changes" });
                }
            },
            error: function () {
                alert('Error occurred');
            }
        });
    }

    // Function to print supplier table
    function printSuppliers() {
        window.open('@Url.Action("PrintSuppliers", "Print")', '_blank');
    }

    // Function to open modal and load data for editing
    function edititem(Id) {
        $.ajax({
            url: '@Url.Action("GetSuppliersId", "Products")',
            type: 'GET',
            data: { id: Id },
            success: function (response) {
                const sup = response.data[0]; 
                $('#txtId').val(sup.supplier_id);
                $('#txtname').val(sup.name);
                $('#txtContactInfo').val(sup.contactinfo);
                $('#modaltitle').text('Edit @ViewBag.Title'); // Correct modal title
                $('#supplierModal').modal('show'); 
            },
            error: function () {
                swal({ icon: "warning", text: 'Error occurred while loading category data', title: "ERROR" });
            }
        });
    }  
    </script>

}