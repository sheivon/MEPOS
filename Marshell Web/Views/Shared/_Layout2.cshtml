<!DOCTYPE html>
<html>
<head>
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8" />
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - GEPOS</title>
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")

    <link rel="icon"
          href="~/Marshell.ico"
          type="image/x-icon" /> 
</head>
<body class="wrapper">
    <!-- Sidebar -->
    <div class="sidebar" data-background-color="dark">
        <div class="sidebar-logo">
            <!-- Logo Header -->
            <div class="logo-header" data-background-color="dark">
                <a href="@Url.Action("Index","Home")" class="logo">
                    <img src="~/Marshell.ico"
                         alt="navbar brand"
                         class="navbar-brand"
                         height="40" />
                </a>
                <div class="nav-toggle">
                    <button class="btn btn-toggle toggle-sidebar">
                        <i class="gg-menu-right"></i>
                    </button>
                    <button class="btn btn-toggle sidenav-toggler">
                        <i class="gg-menu-left"></i>
                    </button>
                </div>
                <button class="topbar-toggler more">
                    <i class="gg-more-vertical-alt"></i>
                </button>
            </div>
            <!-- End Logo Header -->
        </div>
        <div class="sidebar-wrapper scrollbar scrollbar-inner">
            <div class="sidebar-content">
                <ul class="nav nav-secondary">
                    <li class="nav-section">
                        <span class="sidebar-mini-icon">
                            <i class="fa fa-ellipsis-h"></i>
                        </span>
                        <h4 class="text-section">Components</h4>
                    </li>
                    <li class="nav-item">
                        <a data-bs-toggle="collapse" href="#base">
                            <i class="fas fa-users"></i> <!-- Updated icon for Users -->
                            <p>Users</p>
                            <span class="caret"></span>
                        </a>
                        <div class="collapse" id="base">
                            <ul class="nav nav-collapse">
                                <li>
                                    <a href="@Url.Action("Users","Account")">
                                        <span class="sub-item">Users</span>
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </li>
                    <li class="nav-item">
                        <a data-bs-toggle="collapse" href="#forms">
                            <i class="fas fa-pen-square"></i>
                            <p>Product</p>
                            <span class="caret"></span>
                        </a>
                        <div class="collapse" id="forms">
                            <ul class="nav nav-collapse">
                                <!-- Products Menu -->
                                <li>
                                    <a href="@Url.Action("Index","Products")">
                                        <span class="sub-item">
                                            <i class="fa fa-cogs" aria-hidden="true"></i> Products
                                        </span>
                                    </a>
                                </li>
                                <!-- Category Menu -->
                                <li>
                                    <a href="@Url.Action("Index","Category")">
                                        <span class="sub-item">
                                            <i class="fas fa-th-large" aria-hidden="true"></i> Category
                                        </span>
                                    </a>
                                </li>

                                <!-- Sales Menu -->
                                <li>
                                    <a href="@Url.Action("Sales","Products")">
                                        <span class="sub-item">
                                            <i class="fa fa-dollar-sign" aria-hidden="true"></i> Sales
                                        </span>
                                    </a>
                                </li>

                                <!-- Suppliers Menu -->
                                <li>
                                    <a href="@Url.Action("Supplier","Products")">
                                        <span class="sub-item">
                                            <i class="fa fa-truck" aria-hidden="true"></i> Suppliers
                                        </span>
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </li>
                    <li class="nav-item">
                        <a data-bs-toggle="collapse" href="#tables">
                            <i class="fas fa-table"></i>
                            <p>Sales</p>
                            <span class="caret"></span>
                        </a>
                        <div class="collapse" id="tables">
                            <ul class="nav nav-collapse">
                                <li>
                                    <a href="tables/datatables.html">
                                        <span class="sub-item">Sales</span>
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </li>
                    <li class="nav-item">
                        <a data-bs-toggle="collapse" href="#charts">
                            <i class="fas fa-info-circle"></i> <!-- Updated icon for Info -->
                            <p>Info</p>
                            <span class="caret"></span>
                        </a>
                        <div class="collapse" id="charts">
                            <ul class="nav nav-collapse">
                                <li>
                                    <a href="@Url.Action("About","Home")">
                                        <span class="sub-item"><i class="fas fa-users-cog"></i> About</span> <!-- About icon -->
                                    </a>
                                </li>
                                <li>
                                    <a href="@Url.Action("Contact","Home")">
                                        <span class="sub-item"><i class="fas fa-phone-alt"></i> Contact</span> <!-- Contact icon -->
                                    </a>
                                </li>
                            </ul>
                        </div>
                    </li>

                </ul>
            </div>
        </div>
    </div>
    <!-- End Sidebar -->
    <div class="main-panel">
        <div class="main-header">
            <div class="main-header-logo">
                <!-- Logo Header -->
                <div class="logo-header" data-background-color="light">
                    <a href="@Url.Action("index","Home")" class="logo">
                        <img src="~/marshell.ico"
                             alt="navbar brand"
                             class="navbar-brand"
                             height="10" />
                    </a>
                    <div class="nav-toggle">
                        <button class="btn btn-toggle toggle-sidebar">
                            <i class="gg-menu-right"></i>
                        </button>
                        <button class="btn btn-toggle sidenav-toggler">
                            <i class="gg-menu-left"></i>
                        </button>
                    </div>
                    <button class="topbar-toggler more">
                        <i class="gg-more-vertical-alt"></i>
                    </button>
                </div>
            </div>
            <!-- End Logo Header -->
        </div>
    </div>
    <nav class="sb-topnav navbar navbar-expand navbar-dark bg-dark">
        <!-- Sidebar Toggle-->
        <button class="btn btn-link btn-sm order-1 order-lg-0 me-3 me-lg-0" id="sidebarToggle" href="#!"><i class="fas fa-bars"></i></button>
        <!-- Navbar Brand-->
        <a class="navbar-brand ps-3" href="@Url.Action("Index", "Home")"><img src="~/LOGO.ico" style="width:40px;height:40px;" /> Inventario Municipal</a> 
        <!-- Navbar-->
        <ul class="navbar-nav ms-auto d-none d-md-inline-block form-inline ms-auto me-0 me-md-3 my-2 my-md-0 row d-flex">
            <!-- User Avatar login o logout-->
            <li class="nav-item dropdown mt-2">
                @*@{ if (usr != null)
                    {
                        <a class="nav-link dropdown-toggle" id="navbarDropdown" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false"><i class="fas fa-user fa-fw"></i> @(usr.name + " " + usr.srname)</a>
                        <ul class="dropdown-menu dropdown-menu-end mt-2 animated--grow-in" aria-labelledby="navbarDropdown">
                            <li><a class="dropdown-item" href="@Url.Action("Info", "Usuarios")"><i class="fas fa-user-circle"></i>  Cuenta</a></li>
                            <li><hr class="dropdown-divider" /></li>
                            <li><a class="dropdown-item" href="@Url.Action("Cerrar", "Login")"><i class="fas fa-sign-out-alt"></i> Logout</a></li>
                        </ul>}
                    else
                    {*@
                        <a class="nav-link dropdown-toggle" id="navbarDropdown" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false"><i class="fas fa-user fa-fw"></i>Iniciar Session</a>
                        <ul class="dropdown-menu dropdown-menu-end mt-2 animated--grow-in" aria-labelledby="navbarDropdown">
                            <li><hr class="dropdown-divider" /></li>
                            <li><a class="dropdown-item" href="@Url.Action("Index", "Login")">Iniciar Session</a></li>
                        </ul>
                    @*}
                }*@
            </li>
        </ul>
    </nav>
    <div class="container">
        @RenderBody()
    </div>
    <footer class="footer">
        <div class="container-fluid d-flex justify-content-between">
            <nav class="pull-left">
                <ul class="nav">
                    <li class="nav-item">
                        <a class="nav-link" target="_blank" href="https://www.gamboatech.com.ni/">
                            Gamboa Tech
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#"> Help </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="#"> Licenses </a>
                    </li>
                </ul>
            </nav>
            <div>
                Distributed  by
                <a target="_blank" href="https://themewagon.com/">ThemeWagon</a>.
                &amp;
                Designed by
                <a target="_blank" href="http://www.themekita.com">ThemeKita</a>
            </div>
        </div>
    </footer>
    <!-- Include JSZip for Excel export -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>

    <!-- Include pdfMake for PDF export -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/FileSaver.js/2.0.5/FileSaver.min.js"></script>
    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
</body>
</html>
